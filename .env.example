# ============================================
# AI Search Optimizer Pro - Environment Variables
# ============================================
# Copy this to .env.local and fill in your values

# ============================================
# REQUIRED: Clerk Authentication
# ============================================
# Get these from https://dashboard.clerk.com
# 1. Create a new application
# 2. Copy the keys from API Keys section

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# REQUIRED: Stripe Payments
# ============================================
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys for development (start with sk_test_ and pk_test_)

STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Stripe Webhook Secret (for handling payment events)
# Get this when you create a webhook endpoint in Stripe dashboard
# Or use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price ID for Pro subscription
# Create a product in Stripe dashboard, then copy the price ID
STRIPE_PRO_PRICE_ID=price_xxxxx

# ============================================
# OPTIONAL: Enhanced Search APIs
# ============================================
# The app works without these using basic fetch
# Add for better analysis:

# SerpAPI (https://serpapi.com) - for competitor analysis
# SERPAPI_KEY=your_serpapi_key

# ============================================
# App Configuration
# ============================================

# Base URL (change for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Free tier limits
FREE_SCANS_PER_MONTH=3

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600
